      "id": "webview_cef_pubspec_multi_backend_webview_architecture",
      "label": "Multi-backend WebView Architecture",
      "file_type": "rationale",
      "source_file": "packages/webview_cef/pubspec.yaml",
      "source_location": null,
      "source_url": null,
      "captured_at": null,
      "author": null,
      "contributor": null,
      "rationale": "The windows platform was intentionally removed from webview_cef to exclude it from Windows builds, because webview_flutter lacks a Windows backend and the app uses webview_windows (WebView2) on Windows instead. This avoids native compilation failures while keeping Linux/macOS CEF backends."
    },
    {
      "id": "webview_cef_readme_single_process_mode",
      "label": "Single Process Debug Mode in macOS",
      "file_type": "rationale",
      "source_file": "packages/webview_cef/README.md",
      "source_location": null,
      "source_url": null,
      "captured_at": null,
      "author": null,
      "contributor": null,
      "rationale": "The macOS implementation is currently configured in single-process mode (using the --single-process flag) for debugging convenience. Multi-process support is disabled by default to simplify setup and avoid the need for separate helper bundles during development."
    }
